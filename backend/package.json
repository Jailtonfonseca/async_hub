{
    "name": "async-hub-backend",
    "version": "1.0.0",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "migration:run": "ts-node src/migrate.ts",
        "migration:generate": "typeorm migration:generate -d src/data-source.ts src/migrations"
    },
    "dependencies": {
        "amazon-sp-api": "^1.2.0",
        "axios": "^1.4.0",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.3.2",
        "helmet": "^8.1.0",
        "mysql2": "^3.6.0",
        "redis": "^4.7.1",
        "reflect-metadata": "^0.1.13",
        "typeorm": "^0.3.17",
        "winston": "^3.19.0",
        "zod": "^4.4.2"
    },
    "devDependencies": {
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.25",
        "@types/jest": "^30.0.0",
        "@types/node": "^20.4.5",
        "ts-node": "^10.9.1",
        "ts-node-dev": "^2.0.0",
        "typeorm": "^0.3.17",
        "typescript": "^5.1.6",
        "vitest": "^4.1.5"
    }
}
